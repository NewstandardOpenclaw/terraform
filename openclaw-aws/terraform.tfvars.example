aws_region         = "ap-northeast-1"
name_prefix        = "openclaw"
vpc_id             = "vpc-xxxxxxxx"
subnet_id          = "subnet-xxxxxxxx"
ami_id             = "ami-xxxxxxxx"
instance_type      = "t3.small"
key_name           = "your-keypair-name"
allowed_cidrs_ssh  = ["x.x.x.x/32"]
associate_eip      = true
root_volume_size   = 30

tags = {
  Environment = "prod"
  Owner       = "yamamoto"
}
